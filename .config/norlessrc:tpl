<%!
    file_mode = 0o600
%>
[norless]
state_dir = ~/mail
fetch_last = 50
timeout = 60

[maildir inbox]
path = ~/mail/inbox

[maildir sent]
path = ~/mail/sent
sync_new = yes

[maildir imp]
path = ~/mail/imp

[account baverman]
from = ${mail.baverman.efrom}
host = imap.gmail.com
user = ${mail.baverman.user}
trash = [Gmail]/Trash
sync = INBOX -> inbox | [Gmail]/Sent Mail -> sent | imp -> imp
smtp_host = smtp.gmail.com
smtp_port = 587

xoauth2 = yes
xoauth2_client_id = ${mail.baverman.client_id}
xoauth2_secret = ${mail.baverman.secret}
xoauth2_refresh = ${mail.baverman.refresh_token}
